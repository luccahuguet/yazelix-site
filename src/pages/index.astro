---
import FeatureMediaFrame from '../components/FeatureMediaFrame.astro';
import GitHubLink from '../components/GitHubLink.astro';
import SiteNav from '../components/SiteNav.astro';
import { featureItemsById, homepageFeatureIds } from '../data/feature_media';
import '../styles/home.css';

const itemsById = featureItemsById();
const homepageFeatures = homepageFeatureIds
	.map((id) => itemsById.get(id))
	.filter((item): item is NonNullable<typeof item> => item !== undefined);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Yazelix - Reproducible terminal workspace</title>
		<meta
			name="description"
			content="Yazelix is a reproducible terminal workspace built around Zellij, Yazi, Helix, and a fixed runtime toolset."
		/>
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body>
		<div class="page-shell">
			<header class="hero compact-hero">
				<SiteNav active="home" />
				<div class="hero-visual">
					<img src="/images/yazelix_current_example.png" alt="Yazelix terminal workspace screenshot" />
				</div>
				<div class="hero-content">
					<p class="eyebrow">Zellij, Yazi, Helix, terminal, config, and runtime tools in one package</p>
					<h1>Yazelix</h1>
					<p class="hero-copy">
						A reproducible terminal workspace with a managed file tree, stable editor pane, directional
						popups, a right agent sidebar, and a curated runtime that works the same locally or over SSH.
					</p>
					<div class="hero-actions">
						<a class="button primary" href="/start/">Start with Yazelix</a>
						<a class="button secondary" href="/features/">See features</a>
						<a class="button secondary" href="/docs/">Read docs</a>
					</div>
				</div>
			</header>

			<main>
				<section class="section strip">
					<div class="section-inner">
						<h2>Install with one command</h2>
						<p class="section-lede">
							Add the flake output to your profile. After it installs, run `yzx launch` to open the managed
							workspace.
						</p>
						<div class="terminal" aria-label="Yazelix install command">
							<div class="terminal-header">install</div>
							<pre><code>nix profile add github:luccahuguet/yazelix#yazelix</code></pre>
						</div>
					</div>
				</section>

				<section class="section">
					<div class="section-inner">
						<h2>Watch what it does</h2>
						<p class="section-lede">
							The features page shows the workspace flows directly: Yazi jumps, editor targeting, sidebars,
							popups, cursor behavior, widgets, and visual settings.
						</p>
						<div class="feature-preview-grid">
							{homepageFeatures.map((item) => <FeatureMediaFrame item={item} compact />)}
						</div>
					</div>
				</section>

				<section class="section strip">
					<div class="section-inner">
						<h2>Use docs for exact steps</h2>
						<p class="section-lede">
							Docs are for install commands, settings, update paths, recovery, keybindings, and reference
							details. The feature tour is for seeing the workspace.
						</p>
						<div class="blog-grid">
							<article class="panel">
								<h3>Features</h3>
								<p>Workspace screens, opening flows, sidebars, popups, cursors, widgets, and visual settings.</p>
								<a href="/features/">View tour</a>
							</article>
							<article class="panel">
								<h3>Docs</h3>
								<p>Install, configure, update, recover, keybindings, and reference material.</p>
								<a href="/docs/">Docs index</a>
							</article>
							<article class="panel">
								<h3>Blog</h3>
								<p>Release essays, design notes, and product reasoning for the terminal workspace.</p>
								<a href="/blog/">Blog</a>
							</article>
						</div>
					</div>
				</section>
			</main>

			<footer class="footer">
				<div class="footer-inner">
					<span>Yazelix is built by Lucca Huguet</span>
					<GitHubLink label="github.com/luccahuguet/yazelix" class="footer-github-link" showLabel />
				</div>
			</footer>
		</div>
	</body>
</html>
