---
import { getCollection, render } from 'astro:content';
import '../../styles/home.css';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{post.data.title} - Yazelix Blog</title>
		<meta name="description" content={post.data.description} />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body>
		<div class="page-shell">
			<nav class="nav" aria-label="Primary navigation">
				<a class="brand" href="/">
					<img src="/images/logo.png" alt="" />
					<span>Yazelix</span>
				</a>
				<div class="nav-links">
					<a href="/start/">Start</a>
					<a href="/docs/">Docs</a>
					<a href="/blog/">Blog</a>
					<a href="https://github.com/luccahuguet/yazelix">GitHub</a>
				</div>
			</nav>
			<main class="section" style="padding-top: 8rem;">
				<article class="section-inner" style="max-width: 780px;">
					<p class="eyebrow">{post.data.pubDate.toLocaleDateString('en', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
					<h1 style="font-size: clamp(2.4rem, 6vw, 4.2rem);">{post.data.title}</h1>
					<p class="section-lede">{post.data.description}</p>
					<div class="sl-markdown-content" style="margin-top: 2rem;">
						<Content />
					</div>
				</article>
			</main>
		</div>
	</body>
</html>
